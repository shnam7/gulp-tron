{
    "name": "gulp-tron-repo",
    "private": true,
    "scripts": {
        "dev": "turbo dev --filter gulp-tron --filter=@gulp-tron*",
        "dev:all": "turbo dev",
        "build": "turbo build",
        "build:examples": "turbo build --filter=./examples/*",
        "clean": "run-s __clean:tools clean:examples __clean:packages",
        "clean:examples": "turbo clean --filter=./examples/*",
        "__clean:packages": "turbo clean --filter=./packages/*",
        "__clean:tools": "turbo build --filter=gulp-tron... --filter={./packages/plugin-*}...",
        "test": "turbo test",
        "reset": "npm-run-all -s clean reset:turbo reset:node",
        "reset:turbo": "find . -type d -name .turbo -exec rm -rf {} +",
        "reset:node": "find . -type d -name node_modules -exec rm -rf {} +",
        "prepare-to-commit": "run-s clean build clean"
    },
    "license": "MIT",
    "engines": {
        "node": ">=16.14"
    },
    "devDependencies": {
        "npm-run-all": "^4.1.5"
    },
    "packageManager": "pnpm@9.1.1+sha512.14e915759c11f77eac07faba4d019c193ec8637229e62ec99eefb7cf3c3b75c64447882b7c485142451ee3a6b408059cdfb7b7fa0341b975f12d0f7629c71195"
}
