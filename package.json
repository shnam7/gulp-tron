{
    "name": "gulp-tron-repo",
    "private": true,
    "scripts": {
        "dev": "turbo dev --filter gulp-tron --filter=@gulp-tron*",
        "build": "turbo build",
        "build:tron": "turbo build --filter=./packages/gulp-tron",
        "build:packages": "turbo build --filter=./packages/*",
        "lint": "turbo lint",
        "clean": "run-s clean:examples clean:tools",
        "clean:examples": "turbo clean --filter=./examples/*",
        "clean:tools": "turbo clean --filter=gulp-tron... --filter={./packages/plugin-*}...",
        "test": "turbo test",
        "reset": "npm-run-all -s clean reset:turbo reset:node",
        "reset:turbo": "find . -type d -name .turbo -exec rm -rf {} +",
        "reset:node": "find . -type d -name node_modules -exec rm -rf {} +",
        "prepare-to-commit": "run-s build:tron lint test build clean"
    },
    "license": "MIT",
    "engines": {
        "node": ">=16.14"
    },
    "devDependencies": {
        "npm-run-all": "^4.1.5",
        "turbo": "^2.0.9",
        "xo": "^0.59.0"
    },
    "packageManager": "pnpm@9.6.0+sha512.38dc6fba8dba35b39340b9700112c2fe1e12f10b17134715a4aa98ccf7bb035e76fd981cf0bb384dfa98f8d6af5481c2bef2f4266a24bfa20c34eb7147ce0b5e"
}
