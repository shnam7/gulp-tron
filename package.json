{
    "name": "gulp-tron-repo",
    "private": true,
    "scripts": {
        "dev": "turbo dev --filter=gulp-tron --filter=@gulp-tron/plugin-*",
        "build": "turbo build --filter=./examples/*",
        "build:tron": "turbo build --filter=gulp-tron",
        "build:plugins": "turbo build --filter=@gulp-tron/plugin-*",
        "lint": "turbo lint",
        "lint:tron": "turbo lint --filter=gulp-tron",
        "lint:plugins": "turbo lint --filter=@gulp-tron/plugin-*",
        "clean": "run-s clean:examples clean:plugins clean:tron",
        "clean:tron": "turbo clean --filter=gulp-tron",
        "clean:plugins": "turbo clean --filter=@gulp-tron/plugin-*",
        "clean:examples": "turbo clean --filter=./examples/*",
        "xclean:tron": "turbo clean --filter=gulp-tron... --filter={./packages/plugin-*}...",
        "test": "turbo test",
        "test:tron": "turbo test --filter=gulp-tron",
        "test:plugins": "turbo test --filter=@gulp-tron/plugin-*",
        "reset": "npm-run-all -s clean reset:turbo reset:node",
        "reset:turbo": "find . -type d -name .turbo -exec rm -rf {} +",
        "reset:node": "find . -type d -name node_modules -exec rm -rf {} +",
        "prepare-to-commit": "run-s build:tron lint test build clean"
    },
    "license": "MIT",
    "engines": {
        "node": ">=16.14"
    },
    "devDependencies": {
        "npm-run-all": "^4.1.5",
        "turbo": "^2.3.3",
        "xo": "^0.59.3"
    },
    "packageManager": "pnpm@9.14.4"
}
