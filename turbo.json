{
    "$schema": "https://turborepo.com/schema.json",
    "tasks": {
        "dev": {
            "cache": false,
            "persistent": true
        },
        "build": {
            "cache": true,
            "inputs": ["src/**", "tsconfig.json", "tsdown.config.ts"],
            "outputs": ["dist/**"],
            "dependsOn": ["^build"]
        },
        "lint": {
            "cache": false,
            "dependsOn": ["^lint"]
        },
        "test": {
            "cache": false,
            "outputs": ["!coverage/**"],
            "dependsOn": ["^build", "^test"]
        },
        "clean": {
            "cache": false
        }
    }
}
