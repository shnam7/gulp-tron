{{!-- Template: html (top-level layout) --}}
<!DOCTYPE html>
<html>

<head>
    {{#> _head}}{{/_head}}
</head>

<body class="{{ body_class }}">
    <div id="l-site-container">
        <div id="l-header"> {{#> header}}{{/header}} </div>
        <div id="l-content-wrapper">
            <div id="l-page">
                <div id="l-content" class="content">{{#> content}}{{/content}}</div>
                <div id="l-sidebar" class="sidebar">{{#> sidebar}}{{/sidebar}}</div>
            </div>
        </div>
        <div id="l-footer">{{#> footer}}{{/footer}}</div>
        {{#> offcanvas}}{{/offcanvas}}
        {{#> _scripts}}{{/_scripts}}
    </div>
</body>
