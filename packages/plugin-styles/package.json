{
    "name": "@gulp-tron/plugin-styles",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": "./dist/index.js",
        "./*": "./dist/*.js"
    },
    "scripts": {
        "dev": "tsc --watch",
        "lint": "tsc --noEmit && xo",
        "build": "tsc",
        "test": "vitest run --coverage",
        "test:watch": "vitest watch --coverage",
        "clean": "rimraf ./dist ./coverage",
        "rebuild": "runs-s clean build",
        "prepare-to-commit": "run-s lint test build clean",
        "npm-dry-run": "npm publish --dry-run"
    },
    "dependencies": {
        "clean-css": "^5.3.3",
        "gulp-autoprefixer": "^9.0.0",
        "gulp-clean-css": "^4.3.0",
        "gulp-less": "^5.0.0",
        "gulp-postcss": "^10.0.0",
        "gulp-rtlcss": "^2.0.0",
        "gulp-sass": "^6.0.0",
        "postcss": "^8.4.49",
        "postcss-less": "^6.0.0",
        "postcss-reporter": "^7.1.0",
        "postcss-sass": "^0.5.0",
        "postcss-scss": "^4.0.9",
        "sass": "^1.82.0",
        "stylelint": "^16.11.0"
    },
    "devDependencies": {
        "@types/clean-css": "^4.2.11",
        "@types/gulp-autoprefixer": "^0.0.37",
        "@types/gulp-clean-css": "^4.3.4",
        "@types/gulp-less": "^0.0.36",
        "@types/gulp-postcss": "^8.0.6",
        "@types/gulp-sass": "^5.0.4",
        "@types/postcss-less": "^4.0.6",
        "@types/postcss-reporter": "^7.0.5",
        "@types/postcss-sass": "^0.5.0",
        "@types/rtlcss": "^3.5.4",
        "@vitest/coverage-v8": "^2.1.8",
        "@wicle/tsconfig": "github:shnam7/wicle-tsconfig",
        "gulp-tron": "workspace:*",
        "rimraf": "^6.0.1",
        "typescript": "^5.7.2",
        "vitest": "^2.1.8"
    }
}
