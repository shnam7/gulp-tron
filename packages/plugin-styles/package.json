{
    "name": "@gulp-tron/plugin-styles",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": "./dist/index.js",
        "./*": "./dist/*.js"
    },
    "scripts": {
        "dev": "run-s build watch",
        "dev:test": "vitest watch --coverage --coverage.include=src",
        "build": "run-p build:**",
        "build:ts": "tsdown src/index.ts --format cjs,esm --dts",
        "build:ts:types": "tsc --noEmit ",
        "lint": "xo",
        "test": "vitest run --coverage --coverage.include=src",
        "watch": "chokidar 'src/**' -c 'run-p \"build:ts --no-clean\" build:ts:types'",
        "clean": "rimraf ./dist ./coverage",
        "prepare-to-commit": "run-s clean lint test build clean",
        "npm-dry-run": "npm publish --dry-run",
        "reset": "npm-run-all -s clean reset:turbo reset:node",
        "reset:turbo": "find . -type d -name .turbo -exec rm -rf {} +",
        "reset:node": "find . -type d -name node_modules -exec rm -rf {} +"
    },
    "dependencies": {
        "@wicle/is": "^1.0.4",
        "clean-css": "^5.3.3",
        "gulp-autoprefixer": "^9.0.0",
        "gulp-clean-css": "^4.3.0",
        "gulp-less": "^5.0.0",
        "gulp-postcss": "^10.0.0",
        "gulp-rtlcss": "^2.0.0",
        "gulp-sass": "^6.0.1",
        "postcss": "^8.5.6",
        "postcss-less": "^6.0.0",
        "postcss-reporter": "^7.1.0",
        "postcss-sass": "^0.5.0",
        "postcss-scss": "^4.0.9",
        "sass": "^1.91.0",
        "stylelint": "^16.23.1"
    },
    "devDependencies": {
        "@types/clean-css": "^4.2.11",
        "@types/gulp-autoprefixer": "^0.0.37",
        "@types/gulp-clean-css": "^4.3.4",
        "@types/gulp-less": "^0.0.36",
        "@types/gulp-postcss": "^8.0.6",
        "@types/gulp-sass": "^5.0.4",
        "@types/postcss-less": "^4.0.6",
        "@types/postcss-reporter": "^7.0.5",
        "@types/postcss-sass": "^0.5.0",
        "@types/rtlcss": "^3.5.4",
        "@vitest/coverage-v8": "^3.2.4",
        "@gulp-tron/tsconfig": "workspace:*",
        "gulp-tron": "workspace:*",
        "chokidar-cli": "^3.0.0",
        "rimraf": "^6.0.1",
        "tsdown": "^0.14.2",
        "typescript": "^5.9.2",
        "vitest": "^3.2.4",
        "xo": "^1.2.2"
    }
}
