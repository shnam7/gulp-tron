{
    "name": "@gulp-tron/core",
    "version": "1.0.0-alpha.3",
    "description": "Easy to use, flexible gulp build manager",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "types": "./dist/index.d.ts"
        },
        "./*": "./*"
    },
    "files": [
        "dist/*"
    ],
    "scripts": {
        "dev": "run-s build watch",
        "dev:test": "vitest watch --coverage --coverage.include=src",
        "build": "run-p build:**",
        "build:ts": "tsdown src/index.ts --format esm,cjs --dts",
        "build:ts:types": "tsc --noEmit ",
        "lint": "xo",
        "test": "vitest run --coverage --coverage.include=src",
        "watch": "chokidar 'src/**' -c 'run-p \"build:ts --no-clean\" build:ts:types'",
        "clean": "rimraf ./dist ./coverage",
        "prepare-to-commit": "run-s clean lint test build clean",
        "npm-dry-run": "npm publish --dry-run"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/shnam7/gulp-tron"
    },
    "homepage": "https://github.com/shnam7/gulp-tron#readme",
    "bugs": {
        "url": "https://github.com/shnam7/gulp-tron/issues"
    },
    "author": "Robin Nam (https://github.com/shnam7)",
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "gulp",
        "task",
        "build",
        "manager",
        "builder"
    ],
    "dependencies": {
        "@wicle/is": "^1.0.4",
        "@wicle/mutex": "^0.9.0",
        "browser-sync": "^3.0.4",
        "del": "^8.0.0",
        "event-stream": "^4.0.1",
        "globby": "^14.1.0",
        "gulp-changed": "^5.0.2",
        "gulp-debug2": "^1.0.0",
        "gulp-filter": "^9.0.1",
        "gulp-order3": "^1.0.4",
        "gulp-rename": "^2.1.0",
        "multimatch": "^7.0.0",
        "p-event": "^6.0.1",
        "streamqueue": "^2.0.0"
    },
    "peerDependencies": {
        "gulp": "^5.0.0"
    },
    "devDependencies": {
        "@gulp-tron/tsconfig": "workspace:*",
        "@types/browser-sync": "^2.29.0",
        "@types/event-stream": "^4.0.5",
        "@types/gulp": "^4.0.17",
        "@types/gulp-changed": "^0.0.39",
        "@types/gulp-filter": "^3.0.40",
        "@types/gulp-rename": "^2.0.6",
        "@types/merge-stream": "^2.0.0",
        "@types/node": "^24.0.14",
        "@types/vinyl": "^2.0.12",
        "@types/vinyl-fs": "^3.0.6",
        "@vitest/coverage-v8": "^3.2.4",
        "chokidar-cli": "^3.0.0",
        "npm-run-all": "^4.1.5",
        "prettier": "^3.6.2",
        "rimraf": "^6.0.1",
        "tsdown": "^0.12.9",
        "typescript": "^5.8.3",
        "vinyl": "^3.0.1",
        "vitest": "^3.2.4",
        "xo": "^1.2.0"
    },
    "engines": {
        "node": ">=16.9"
    }
}
