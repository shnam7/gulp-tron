{
    "name": "@gulp-tron/plugin-scripts",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": "./dist/index.js",
        "./*": "./dist/*.js"
    },
    "scripts": {
        "dev": "run-s build watch",
        "dev:test": "vitest watch --coverage --coverage.include=src",
        "build": "run-p build:**",
        "build:ts": "tsdown src/index.ts --format cjs,esm --dts",
        "build:ts:types": "tsc --noEmit ",
        "lint": "xo",
        "test": "vitest run --coverage --coverage.include=src",
        "watch": "chokidar 'src/**' -c 'run-p \"build:ts --no-clean\" build:ts:types'",
        "clean": "rimraf ./dist ./coverage",
        "prepare-to-commit": "run-s clean lint test build clean",
        "npm-dry-run": "npm publish --dry-run",
        "reset": "npm-run-all -s clean reset:turbo reset:node",
        "reset:turbo": "find . -type d -name .turbo -exec rm -rf {} +",
        "reset:node": "find . -type d -name node_modules -exec rm -rf {} +"
    },
    "dependencies": {
        "@babel/core": "^7.28.0",
        "gulp-babel": "^8.0.0",
        "gulp-coffee": "^3.0.3",
        "gulp-coffeelint": "^0.6.0",
        "gulp-concat": "^2.6.1",
        "gulp-eslint-new": "^2.4.0",
        "gulp-terser": "^2.1.0"
    },
    "devDependencies": {
        "@types/gulp-babel": "^6.1.33",
        "@types/gulp-coffeelint": "^0.0.35",
        "@types/gulp-concat": "^0.0.37",
        "@types/gulp-rename": "^2.0.6",
        "@types/gulp-terser": "^1.2.6",
        "@vitest/coverage-v8": "^3.2.4",
        "@gulp-tron/tsconfig": "workspace:*",
        "@gulp-tron/core": "workspace:*",
        "chokidar-cli": "^3.0.0",
        "rimraf": "^6.0.1",
        "tsdown": "^0.12.9",
        "typescript": "^5.8.3",
        "vitest": "^3.2.4",
        "xo": "^1.2.0"
    }
}
