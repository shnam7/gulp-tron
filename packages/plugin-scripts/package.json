{
    "name": "@gulp-tron/plugin-scripts",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": "./dist/index.js",
        "./*": "./dist/*.js"
    },
    "scripts": {
        "dev": "tsc --watch",
        "lint": "tsc --noEmit && xo",
        "build": "tsc",
        "test": "vitest run --coverage",
        "test:watch": "vitest watch --coverage",
        "clean": "rimraf ./dist ./coverage",
        "rebuild": "runs-s clean build",
        "prepare-to-commit": "run-s lint test build clean",
        "npm-dry-run": "npm publish --dry-run"
    },
    "dependencies": {
        "@babel/core": "^7.27.4",
        "gulp-babel": "^8.0.0",
        "gulp-coffee": "^3.0.3",
        "gulp-coffeelint": "^0.6.0",
        "gulp-concat": "^2.6.1",
        "gulp-eslint-new": "^2.4.0",
        "gulp-terser": "^2.1.0"
    },
    "devDependencies": {
        "@types/gulp-babel": "^6.1.33",
        "@types/gulp-coffeelint": "^0.0.35",
        "@types/gulp-concat": "^0.0.37",
        "@types/gulp-rename": "^2.0.6",
        "@types/gulp-terser": "^1.2.6",
        "@vitest/coverage-v8": "^3.2.2",
        "@wicle/tsconfig": "github:shnam7/wicle-tsconfig",
        "gulp-tron": "workspace:*",
        "rimraf": "^6.0.1",
        "typescript": "^5.8.3",
        "vitest": "^3.2.2",
        "xo": "^1.0.5"
    }
}
