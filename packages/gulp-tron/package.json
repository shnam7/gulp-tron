{
    "name": "gulp-tron",
    "version": "1.0.0-alpha.3",
    "description": "Easy to use, flexible gulp build manager",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        "require": "./dist/index.cjs",
        "import": "./dist/index.js"
    },
    "files": [
        "dist/*"
    ],
    "scripts": {
        "dev": "pnpm run build --watch",
        "build": "tsup src/index.ts --format cjs,esm --dts",
        "build-minify": "tsup src/index.ts --format cjs,esm --dts --minify",
        "lint": "tsc && xo",
        "clean": "rimraf ./dist ./coverage",
        "test": "vitest run --coverage",
        "test:watch": "vitest watch --coverage",
        "rebuild": "run-s clean build",
        "prepare-to-commit": "run-s rebuild lint test",
        "npm-dry-run": "npm publish --dry-run"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/shnam7/gulp-tron"
    },
    "homepage": "https://github.com/shnam7/gulp-tron#readme",
    "bugs": {
        "url": "https://github.com/shnam7/gulp-tron/issues"
    },
    "author": "Robin Nam (https://github.com/shnam7)",
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "gulp",
        "task",
        "build",
        "manager",
        "builder"
    ],
    "dependencies": {
        "@wicle/mutex": "^0.9.0",
        "browser-sync": "^3.0.2",
        "del": "^7.1.0",
        "event-stream": "^4.0.1",
        "globby": "^14.0.2",
        "gulp-changed": "^5.0.2",
        "gulp-debug2": "^1.0.0",
        "gulp-filter": "^9.0.1",
        "gulp-order3": "^1.0.4",
        "gulp-rename": "^2.0.0",
        "multimatch": "^7.0.0",
        "p-event": "^6.0.1",
        "streamqueue": "^1.1.2",
        "through2": "^4.0.2",
        "vinyl-fs": "^4.0.0"
    },
    "peerDependencies": {
        "gulp": "^5.0.0"
    },
    "devDependencies": {
        "@types/browser-sync": "^2.29.0",
        "@types/event-stream": "^4.0.5",
        "@types/gulp": "^4.0.17",
        "@types/gulp-changed": "^0.0.39",
        "@types/gulp-debug": "^2.0.36",
        "@types/gulp-filter": "^3.0.39",
        "@types/gulp-rename": "^2.0.6",
        "@types/merge-stream": "^1.1.5",
        "@types/node": "^20.14.10",
        "@types/p-event": "^3.0.0",
        "@types/through2": "^2.0.41",
        "@types/vinyl": "^2.0.12",
        "@types/vinyl-fs": "^3.0.5",
        "@vitest/coverage-v8": "^1.6.0",
        "@wicle/tsconfig": "github:shnam7/wicle-tsconfig",
        "npm-run-all": "^4.1.5",
        "rimraf": "^5.0.8",
        "tsup": "^8.1.0",
        "typescript": "^5.5.3",
        "vinyl": "^3.0.0",
        "vitest": "^1.6.0",
        "xo": "^0.58.0"
    },
    "engines": {
        "node": ">=15"
    }
}
