{
    "name": "@gulp-tron/plugin-utils",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": "./dist/index.js",
        "./*": "./dist/*.js"
    },
    "scripts": {
        "dev": "tsc --watch",
        "lint": "tsc --noEmit && xo",
        "build": "tsc",
        "test": "vitest run --coverage",
        "test:watch": "vitest watch --coverage",
        "clean": "rimraf ./dist ./coverage",
        "rebuild": "run-s clean build",
        "prepare-to-commit": "run-s lint test build clean",
        "npm-dry-run": "npm publish --dry-run"
    },
    "dependencies": {
        "fast-glob": "^3.3.3",
        "gulp-concat": "^2.6.1",
        "gulp-data": "^1.3.1",
        "gulp-imagemin": "^9.1.0",
        "js-yaml": "^4.1.0"
    },
    "devDependencies": {
        "@types/gulp-concat": "^0.0.37",
        "@types/gulp-imagemin": "^8.0.6",
        "@types/imagemin": "^9.0.1",
        "@types/js-yaml": "^4.0.9",
        "@types/through2": "^2.0.41",
        "@vitest/coverage-v8": "^3.2.2",
        "@wicle/tsconfig": "github:shnam7/wicle-tsconfig",
        "gulp-tron": "workspace:*",
        "rimraf": "^6.0.1",
        "typescript": "^5.8.3",
        "vitest": "^3.2.2",
        "xo": "^1.1.0"
    }
}
